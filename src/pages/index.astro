---
import Layout from "../layouts/Layout.astro";
import Link from "../components/Link.astro";

interface Item {
  name: string;
  description: string;
  url: string;
  isExternal: boolean;
}

const projects: Item[] = [
  {
    name: "[2026-04-29] initial end-to-end spike",
    description: "exploring how to save, annotate, and share bookmarks",
    url: "/20260429/",
    isExternal: false,
  },
];
---

<Layout>
  <main class="[&_p]:text-muted-foreground">
    <div class="flex flex-col gap-2">
      {
        projects.map((project) => (
          <a
            class="hover:bg-muted -mx-3 flex flex-col rounded-md px-3 py-2 no-underline"
            href={project.url}
            target={project.isExternal ? "_blank" : undefined}
            rel={project.isExternal ? "noopener noreferrer" : undefined}
          >
            <span>{project.name}</span>
            <span class="text-muted-foreground">{project.description}</span>
          </a>
        ))
      }
    </div>
    <h2>Learn More</h2>
    <p>
      <Link url="https://likes.fyi">likes.fyi</Link> is an open source toolkit
      for sharing the links you like with the people you love. You've found our
      museum of curiosities, a graveyard of prototypes and hacks built while
      figuring out what the heck likes.fyi even was.
    </p>

    <p>
      To learn more head to <Link url="https://likes.fyi">likes.fyi</Link> or
      check out the code on <Link url="https://github.com/likes-fyi">GitHub</Link>
      or <Link url="https://tangled.org/likes.fyi">tangled</Link>. You can also
      follow us on bsky at <Link url="https://bsky.app/profile/likes.fyi">@likes.fyi</Link>.
    </p>
  </main>
</Layout>
